# =============================================================================
#  Xaero MapSync — SERVER configuration
#  Rename this file to: server.env
# =============================================================================

# Network ──────────────────────────────────────────────────────────────────────

# IP address to bind on.
# 0.0.0.0 accepts connections from any IP (required for port-forwarded server).
# Use 127.0.0.1 for local testing only.
HOST=0.0.0.0

# Port to listen on. You must forward this port on your router so other
# players can reach you from the internet.
PORT=8765

# Storage ──────────────────────────────────────────────────────────────────────

# Directory where the canonical "golden copy" of all merged region files
# is stored. Created automatically if it doesn't exist.
GOLDEN_COPY_DIR=./golden

# Directory where timestamped backups of the golden copy are stored.
# A full backup is taken each time the server starts.
# Created automatically if it doesn't exist.
BACKUP_DIR=./golden_backups

# Maximum number of golden-copy backups to keep.
# Older backups are pruned automatically when this limit is exceeded.
MAX_BACKUPS=10
