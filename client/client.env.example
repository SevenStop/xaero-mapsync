# =============================================================================
#  Xaero MapSync — CLIENT configuration
#  Rename this file to: client.env
# =============================================================================

# Server ───────────────────────────────────────────────────────────────────────

# Full URL of the sync server, including port.
# If you are the host player, use localhost.
# Other players use the host's public IP or domain name.
SERVER_URL=http://your-server-ip-or-domain:8765

# Your in-game username. Used to label your uploads in the server log.
PLAYER_ID=YourMinecraftUsername

# Map folder ───────────────────────────────────────────────────────────────────

# Full path to the Xaero world-map folder for the specific server you want
# to sync. This is the folder that contains null/, DIM-1/, DIM1/ etc.
#
# Windows example:
MAP_DIR=C:/Users/YourName/AppData/Roaming/.minecraft/xaero/world-map/Multiplayer_yourserver.net
#
# Linux / macOS example:
# MAP_DIR=/home/you/.minecraft/xaero/world-map/Multiplayer_yourserver.net

# Sync interval ────────────────────────────────────────────────────────────────

# How often (in minutes) to run a full sync cycle.
# The first sync always runs immediately on startup.
SYNC_INTERVAL_MINUTES=30

# Backups ──────────────────────────────────────────────────────────────────────

# Directory where local map backups are stored.
# A full backup of your map folder is taken before every sync cycle.
# Created automatically if it doesn't exist.
BACKUP_DIR=./backups

# Maximum number of local backups to keep.
# Older backups are pruned automatically when this limit is exceeded.
# Increase this if you want a longer rollback history.
MAX_BACKUPS=5

# Fabric mod ───────────────────────────────────────────────────────────────────

# Port that the companion Fabric mod listens on for pause/reload commands.
# Must match SOCKET_PORT in XaeroMapsyncClient.java (default: 25566).
# Change both if 25566 is already in use on your machine.
MOD_RELOAD_PORT=25566

# Manifest timeout ─────────────────────────────────────────────────────────────

# Seconds to wait for the server to respond to a manifest request.
# With SHA256 sidecars cached on the server this should be fast, but
# set generously for the first startup while sidecars are being backfilled.
MANIFEST_TIMEOUT_SECONDS=90
